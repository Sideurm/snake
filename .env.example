# Primary Supabase database URL (recommended)
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Token secret used by current custom backend auth
SUPABASE_AUTH_JWT_SECRET=replace_with_long_random_secret

# Optional fallback names supported by code
# SUPABASE_DATABASE_URL=
# DATABASE_URL=
# NETLIFY_DATABASE_URL=
# SUPABASE_JWT_SECRET=
# AUTH_JWT_SECRET=
# NETLIFY_AUTH_JWT_SECRET=

# Optional TLS strict mode
# DB_SSL_STRICT=false
